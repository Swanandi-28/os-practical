nano nandu.c

#include<stdio.h>
#include<unistd.h>

int main(int argc, char *argv[])
{
    if(argc!=3) 
    {
        printf("Usage: %s Source Destination\n",argv[0]);
        return 1;
    }

    if(rename(argv[1],argv[2])==0)
    {
        printf("File renamed successfully.\n");
    }
    else
    {
        perror("Error");
        return 0;
    }
}

gcc nandu.c -o mymv
