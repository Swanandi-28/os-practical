nano demo.sh

#!/bin/bash
echo "Enter first number"
read a
echo "Enter second number"
read b
echo 1. "Addition"
echo 2. "Subtraction"
echo 3. "Multiplication"
echo 4. "Division'
read choice
case $choice in
1)
echo "Add:$((a+b))";;
2)
echo "Sub:$((a-b))";;
3)
echo "Mul:$((a*b))";;
4)
echo "Div:$((a/b))";;
5)
echo "Invalid choice";;
esac


chmod +x demo.sh
./demo.sh
